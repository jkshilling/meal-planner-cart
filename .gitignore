# Dependencies
node_modules/

# Local database + WAL/SHM sidecars
data/app.db
data/app.db-journal
data/app.db-shm
data/app.db-wal

# Daily fetch cron log (retired Spoonacular cron — kept the ignore so any
# stragglers on existing checkouts don't show up in git status).
data/fetch.log

# Chrome extension packed-output artifacts. The .pem is the private key
# used to sign the extension; committing it would let anyone impersonate
# our extension's identity. The .crx is the packed binary, regenerable
# from the unpacked source — no need to track.
chrome-extension/*.pem
chrome-extension/*.crx
chrome-extension/**/*.pem
chrome-extension/**/*.crx

# Environment
.env

# OS
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*

# Editors
.vscode/
.idea/
