# Local dev example — copy to .env and adjust.
# On the shared droplet, use the production values noted next to each var.

# App port. Local dev can be anything; on the grabbag droplet use 8002 (reserved for this app).
PORT=3000

# Loopback only. Do NOT change to 0.0.0.0 on the droplet — nginx is the front door.
HOST=127.0.0.1

NODE_ENV=development
# On the droplet: NODE_ENV=production

SESSION_SECRET=change-me-to-a-long-random-string

# Walmart browser automation.
#   WALMART_ENABLED=true  → matching + add-to-cart routes active, UI shows them
#   WALMART_ENABLED=false → those routes 404, UI hides them (safe for headless servers)
# The droplet is headless, so production must be false. Local Mac should be true.
WALMART_ENABLED=true

# Only read when WALMART_ENABLED=true. Leave false on local Mac so you can
# watch Chromium and complete any manual login/captcha.
WALMART_HEADLESS=false

# USDA FoodData Central API key, used as a backup nutrition lookup when
# Spoonacular's response lacks nutrient data, and for the "Pre-fill from
# USDA" button on the manual recipe form. DEMO_KEY works but is rate-
# limited to 30 req/hr per IP. Sign up free at https://api.data.gov/signup/
# for 1,000 req/hr.
USDA_API_KEY=DEMO_KEY

# Spoonacular API key — recipe search source (~360k recipes, with real
# nutrition + cost included). Sign up free at https://spoonacular.com/food-api
# for 150 points/day. The "Search online" feature is disabled when this
# is empty.
SPOONACULAR_API_KEY=
