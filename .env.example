# Local dev example — copy to .env and adjust.
# On the shared droplet, use the production values noted next to each var.

# App port. Local dev can be anything; on the grabbag droplet use 8002 (reserved for this app).
PORT=3000

# Loopback only. Do NOT change to 0.0.0.0 on the droplet — nginx is the front door.
HOST=127.0.0.1

NODE_ENV=development
# On the droplet: NODE_ENV=production

SESSION_SECRET=change-me-to-a-long-random-string

# USDA FoodData Central API key, used to look up per-ingredient nutrition
# (calories, protein, carbs, fat, fiber, sugar, sodium). DEMO_KEY works
# but is rate-limited to 30 req/hr per IP. Sign up free at
# https://api.data.gov/signup/ for 1,000 req/hr.
USDA_API_KEY=DEMO_KEY

# OpenAI API key — used as a last-resort fallback when USDA can't match an
# ingredient name. services/usda.searchFood asks gpt-4o-mini to rewrite
# the name to a USDA-friendlier canonical form, then retries USDA. Each
# unique unmatched name is one LLM call lifetime (results cached in
# nutrition_lookups), so cost is essentially zero — pennies for hundreds
# of names. Leave empty to disable the fallback (USDA-only behavior).
OPENAI_API_KEY=

# Override the model used for ingredient normalization. Defaults to
# gpt-4o-mini, which is cheap and reliable for this single-token task.
# Only relevant when OPENAI_API_KEY is set.
OPENAI_MODEL=gpt-4o-mini

# Resend transactional-email API key. Used by the password-reset flow
# (/forgot-password). When empty, /forgot-password still appears to work
# (shows the generic "if an account exists…" page) but no email is sent.
# Get a key + verify your sending domain at https://resend.com.
RESEND_API_KEY=

# Sender for outbound transactional emails. The domain must be verified
# in your Resend account. Format: "Name <addr@verified.domain>". The default
# (onboarding@resend.dev) only works for sending to YOUR Resend-account
# email address — fine for testing, swap before letting real users use
# /forgot-password.
EMAIL_FROM=Meal Planner <onboarding@resend.dev>

# Absolute base URL of the deployed app. Used to build the reset link in
# password-reset emails (otherwise the user gets a useless relative URL).
# Production: https://meals.alaskatargeting.com
APP_URL=http://localhost:3000
