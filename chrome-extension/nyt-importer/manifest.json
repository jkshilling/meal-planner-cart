{
  "manifest_version": 3,
  "name": "NYT Cooking → Meal Planner",
  "version": "0.1.0",
  "description": "One-click import recipes from NYT Cooking into your Meal Planner library.",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": [
    "https://cooking.nytimes.com/*",
    "https://meals.alaskatargeting.com/*",
    "http://localhost:3000/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Import this recipe to Meal Planner",
    "default_icon": {
      "16": "icon-16.png",
      "48": "icon-48.png",
      "128": "icon-128.png"
    }
  },
  "options_page": "options.html",
  "icons": {
    "16": "icon-16.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  }
}
