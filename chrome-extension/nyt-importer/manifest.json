{
  "manifest_version": 3,
  "name": "NYT Recipe Clipper",
  "version": "0.2.0",
  "description": "One-click import recipes from NYT Cooking, Bon Appétit, Serious Eats, food52, and any site publishing schema.org Recipe JSON-LD.",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": [
    "https://meals.alaskatargeting.com/*",
    "http://localhost:3000/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Clip this recipe",
    "default_icon": {
      "16": "icon-16.png",
      "48": "icon-48.png",
      "128": "icon-128.png"
    }
  },
  "options_page": "options.html",
  "icons": {
    "16": "icon-16.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  }
}
