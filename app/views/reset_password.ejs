<%- include('partials/header') %>
<div style="max-width: 420px; margin: 40px auto;">
  <h1>Choose a new password</h1>
  <% if (flash) { %><div class="flash <%= flash.type %>"><%= flash.message %></div><% } %>
  <section class="card">
    <% if (invalid) { %>
      <p>This reset link is invalid or has expired.</p>
      <p style="margin-top: 14px; text-align: center;">
        <a href="/forgot-password">Request a new link</a> · <a href="/login">Sign in</a>
      </p>
    <% } else { %>
      <form method="post" action="/reset-password/<%= token %>" class="stack">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <label>New password
          <input type="password" name="password" required minlength="8" autofocus autocomplete="new-password" />
          <span class="muted tiny">Minimum 8 characters.</span>
        </label>
        <label>Confirm new password
          <input type="password" name="confirm" required minlength="8" autocomplete="new-password" />
        </label>
        <button class="btn primary" type="submit" style="width: 100%;">Update password</button>
      </form>
    <% } %>
  </section>
</div>
<%- include('partials/footer') %>
