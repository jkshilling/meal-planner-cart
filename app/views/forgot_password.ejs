<%- include('partials/header') %>
<div style="max-width: 420px; margin: 40px auto;">
  <h1>Reset password</h1>
  <% if (flash) { %><div class="flash <%= flash.type %>"><%= flash.message %></div><% } %>
  <section class="card">
    <% if (sent) { %>
      <p>If an account exists for <strong><%= email %></strong>, a password-reset link is on its way.
        The link expires in 1 hour.</p>
      <p class="muted tiny">Don't see it? Check spam, then <a href="/forgot-password">try again</a>.</p>
      <p style="margin-top: 14px; text-align: center;"><a href="/login">Back to sign in</a></p>
    <% } else { %>
      <form method="post" action="/forgot-password" class="stack">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <label>Email
          <input type="email" name="email" required autofocus
                 value="<%= email %>" autocomplete="email" />
          <span class="muted tiny">We'll email a link you can click to set a new password.</span>
        </label>
        <button class="btn primary" type="submit" style="width: 100%;">Send reset link</button>
      </form>
      <p class="muted tiny" style="margin: 14px 0 0; text-align: center;">
        Remembered it? <a href="/login">Sign in</a>
      </p>
    <% } %>
  </section>
</div>
<%- include('partials/footer') %>
