<%- include('partials/header') %>
<h1>Shopping + Walmart Match</h1>
<p><a href="/plan/<%= plan.id %>">← back to plan</a></p>

<section class="card">
  <h2>Shopping list</h2>
  <% if (!items.length) { %>
    <p class="muted">Empty. Build a list from the approved plan first.</p>
  <% } else { %>
    <table class="grid-table">
      <thead><tr><th>Name</th><th>Qty</th><th>Unit</th><th>Brand</th><th>Approved</th><th></th><th></th></tr></thead>
      <tbody>
        <% items.forEach(function(it) { %>
          <tr>
            <td>
              <form id="upd-<%= it.id %>" method="post" action="/plan/<%= plan.id %>/shopping/item">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                <input type="hidden" name="action" value="update" />
                <input type="hidden" name="item_id" value="<%= it.id %>" />
                <input name="name" value="<%= it.name %>" form="upd-<%= it.id %>" />
              </form>
            </td>
            <td><input name="quantity" type="number" step="0.5" min="0" value="<%= it.quantity %>" form="upd-<%= it.id %>" /></td>
            <td><input name="unit" value="<%= it.unit %>" form="upd-<%= it.id %>" /></td>
            <td><input name="brand" value="<%= it.brand_preference || '' %>" form="upd-<%= it.id %>" /></td>
            <td><input type="checkbox" name="approved" value="1" <%= it.approved ? 'checked' : '' %> form="upd-<%= it.id %>" /></td>
            <td><button class="link" type="submit" form="upd-<%= it.id %>">save</button></td>
            <td>
              <form method="post" action="/plan/<%= plan.id %>/shopping/item">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                <input type="hidden" name="action" value="delete" />
                <input type="hidden" name="item_id" value="<%= it.id %>" />
                <button class="link" type="submit">delete</button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } %>

  <form method="post" action="/plan/<%= plan.id %>/shopping/item" class="row" style="margin-top:12px">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
    <input type="hidden" name="action" value="add" />
    <input name="name" placeholder="add item…" required />
    <input name="quantity" type="number" step="0.5" min="0" value="1" />
    <input name="unit" value="each" />
    <input name="brand" placeholder="brand (optional)" />
    <button class="btn" type="submit">Add</button>
  </form>
</section>

<% if (walmartEnabled) { %>
<section class="card">
  <h2>Walmart matches</h2>
  <form method="post" action="/plan/<%= plan.id %>/match-walmart" class="inline-form">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
    <button class="btn primary" type="submit">Run Walmart match</button>
  </form>
  <p class="muted tiny">Opens a real Chromium browser (headed by default). Walmart may require a captcha or login — if matching stops early, finish that in the browser and re-run.</p>

  <% if (!matches.length) { %>
    <p class="muted">No matches yet.</p>
  <% } else { %>
    <table class="grid-table matches">
      <thead><tr><th>Item</th><th>Match</th><th>Price</th><th>Size</th><th>Confidence</th><th>Approved</th><th>Alternatives</th></tr></thead>
      <tbody>
        <% matches.forEach(function(m) { %>
          <tr class="confidence-<%= m.confidence %>">
            <td><%= m.item_name %></td>
            <td>
              <% if (m.product_url) { %><a href="<%= m.product_url %>" target="_blank"><%= m.product_name || '(no name)' %></a>
              <% } else { %><em class="muted">no match</em><% } %>
            </td>
            <td><%= m.product_price ? ('$' + m.product_price.toFixed(2)) : '—' %></td>
            <td><%= m.product_size || '—' %></td>
            <td><span class="tag confidence-<%= m.confidence %>"><%= m.confidence %></span></td>
            <td>
              <form method="post" action="/plan/<%= plan.id %>/shopping/approve-match" style="display:inline">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                <input type="hidden" name="item_id" value="<%= m.shopping_item_id %>" />
                <% if (m.approved) { %>
                  <input type="hidden" name="action" value="unapprove" />
                  <button class="link" type="submit">✓ approved — click to undo</button>
                <% } else { %>
                  <input type="hidden" name="action" value="approve" />
                  <button class="link" type="submit">approve</button>
                <% } %>
              </form>
            </td>
            <td>
              <% var cands = m.candidates_json ? JSON.parse(m.candidates_json) : []; %>
              <% if (cands.length > 1) { %>
                <form method="post" action="/plan/<%= plan.id %>/shopping/approve-match">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                  <input type="hidden" name="item_id" value="<%= m.shopping_item_id %>" />
                  <input type="hidden" name="action" value="pick" />
                  <select name="candidate_index">
                    <% cands.forEach(function(c, i) { %>
                      <option value="<%= i %>"><%= c.name.substring(0, 40) %><%= c.price ? ' — $' + c.price : '' %></option>
                    <% }) %>
                  </select>
                  <button class="link" type="submit">use this</button>
                </form>
              <% } else { %><span class="muted">—</span><% } %>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } %>
</section>

<% var anyApproved = matches.some(function(m) { return m.approved; }); %>
<% if (anyApproved) { %>
  <form method="post" action="/plan/<%= plan.id %>/add-to-cart" class="inline-form">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
    <button class="btn primary" type="submit">Add approved items to Walmart cart →</button>
  </form>
  <p class="muted tiny">Automation opens Walmart, pauses for manual login if needed, then adds approved items. It will NOT check out.</p>
<% } %>
<% } else { %>
<section class="card">
  <p class="muted">Walmart automation is disabled on this deployment. Run the app on a machine with a browser to match and add to cart.</p>
</section>
<% } %>

<%- include('partials/footer') %>
