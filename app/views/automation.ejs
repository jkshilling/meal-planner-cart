<%- include('partials/header') %>
<h1>Automation Run #<%= run.id %></h1>
<p>Status: <strong><%= run.status %></strong> · Started <%= run.started_at %><%= run.finished_at ? ' · Finished ' + run.finished_at : '' %></p>
<p><strong><%= run.success_count %></strong> added · <strong><%= run.failure_count %></strong> failed</p>
<section class="card">
  <h2>Per-item log</h2>
  <% if (!run.log.length) { %><p class="muted">No log entries.</p><% } else { %>
    <table class="grid-table">
      <thead><tr><th>Item</th><th>Product</th><th>Result</th><th>Reason</th></tr></thead>
      <tbody>
        <% run.log.forEach(function(e) { %>
          <tr class="<%= e.ok ? 'ok' : 'fail' %>">
            <td><%= e.item || '—' %></td>
            <td><%= e.product || e.error || '—' %></td>
            <td><%= e.ok ? '✓' : (e.error ? 'error' : '✗') %></td>
            <td><%= e.reason || '' %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } %>
</section>
<p><a class="btn" href="/plan/<%= run.plan_id %>/shopping">Back to shopping list</a></p>
<%- include('partials/footer') %>
