<%- include('partials/header') %>
<h1>Settings</h1>
<% if (saved) { %><div class="flash success">Saved.</div><% } %>
<form method="post" action="/settings" class="stack">
  <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
  <div class="card">
    <h2>Household</h2>
    <label>Name <input name="name" value="<%= profile.name %>" /></label>
    <label>Weekly grocery budget ($) <input name="budget_weekly" type="number" step="0.01" min="0" value="<%= profile.budget_weekly %>" /></label>
    <label>Max prep time per meal (min) <input name="max_prep_time" type="number" min="5" value="<%= profile.max_prep_time %>" /></label>

    <fieldset>
      <legend>Meal types planned</legend>
      <% ['breakfast','lunch','snack','dinner'].forEach(function(t) { %>
        <label class="inline"><input type="checkbox" name="meal_<%= t %>" <%= profile.meal_types.includes(t) ? 'checked' : '' %>/> <%= t %></label>
      <% }) %>
    </fieldset>

    <fieldset>
      <legend>Pair sides with</legend>
      <% var pair = JSON.parse(profile.pair_sides_with_json || '[]'); %>
      <% ['lunch','dinner'].forEach(function(t) { %>
        <label class="inline"><input type="checkbox" name="pair_sides_<%= t %>" <%= pair.includes(t) ? 'checked' : '' %>/> <%= t %></label>
      <% }) %>
      <p class="muted tiny" style="margin: 4px 0 0">Each main gets a paired side recipe; the planner avoids carb-on-carb pairings (no rice with pasta, etc.).</p>
    </fieldset>

    <fieldset>
      <legend>Optimization mode (after budget)</legend>
      <% ['lowest_cost','healthiest','least_prep_time'].forEach(function(m) { %>
        <label class="inline"><input type="radio" name="optimization_mode" value="<%= m %>" <%= profile.optimization_mode === m ? 'checked' : '' %>/> <%= m.replace(/_/g,' ') %></label>
      <% }) %>
    </fieldset>

    <label class="inline"><input type="checkbox" name="breakfast_simplicity" <%= profile.breakfast_simplicity ? 'checked' : '' %>/> Prefer simpler breakfasts</label>
  </div>

  <div class="card">
    <h2>Household members</h2>
    <p class="muted">Add one row per person. For each meal, choose <em>plan</em> if you want a planned meal for that person, <em>school</em> if it's covered elsewhere (school lunch, free breakfast program), or <em>skip</em> if they don't eat it. <em>school</em> and <em>skip</em> behave the same way for the planner — both mean "don't shop or schedule for this meal."</p>
    <%
      // Default behavior for new/unsaved rows.
      var defaultBehavior = { breakfast: 'plan', lunch: 'plan', snack: 'plan', dinner: 'plan' };
      var rows = profile.members.length
        ? profile.members
        : [{ name: '', label: 'adult', meal_behavior: defaultBehavior }];
    %>
    <table class="grid-table">
      <thead>
        <tr>
          <th>Name</th>
          <th>Label</th>
          <th>Breakfast</th>
          <th>Lunch</th>
          <th>Snack</th>
          <th>Dinner</th>
        </tr>
      </thead>
      <tbody id="members">
        <% rows.forEach(function(m) { var mb = m.meal_behavior || defaultBehavior; %>
          <tr>
            <td><input name="member_name" value="<%= m.name %>" /></td>
            <td><select name="member_label">
              <option value="adult" <%= m.label==='adult' ? 'selected' : '' %>>adult</option>
              <option value="child" <%= m.label==='child' ? 'selected' : '' %>>child</option>
              <option value="teen" <%= m.label==='teen' ? 'selected' : '' %>>teen</option>
            </select></td>
            <% ['breakfast','lunch','snack','dinner'].forEach(function(meal) { %>
              <td><select name="member_<%= meal %>">
                <option value="plan"   <%= mb[meal]==='plan'   ? 'selected' : '' %>>plan</option>
                <option value="school" <%= mb[meal]==='school' ? 'selected' : '' %>>school</option>
                <option value="skip"   <%= mb[meal]==='skip'   ? 'selected' : '' %>>skip</option>
              </select></td>
            <% }) %>
          </tr>
        <% }) %>
      </tbody>
    </table>
    <button type="button" class="btn" onclick="addMember()">Add member</button>
  </div>

  <div class="card">
    <h2>Preferences</h2>
    <label>Dietary constraints (comma separated) <input name="dietary_constraints" value="<%= JSON.parse(profile.dietary_constraints_json).join(', ') %>" placeholder="vegetarian, gluten-free" /></label>
    <label>Allergies <input name="allergies" value="<%= JSON.parse(profile.allergies_json).join(', ') %>" placeholder="peanut, shellfish" /></label>
    <label>Disliked ingredients <input name="disliked_ingredients" value="<%= JSON.parse(profile.disliked_ingredients_json).join(', ') %>" /></label>
    <label>Favorite meal keywords <input name="favorite_meals" value="<%= JSON.parse(profile.favorite_meals_json).join(', ') %>" placeholder="tacos, pasta" /></label>
    <label>Preferred cuisines <input name="preferred_cuisines" value="<%= JSON.parse(profile.preferred_cuisines_json).join(', ') %>" placeholder="italian, mexican" /></label>
  </div>

  <button class="btn primary" type="submit">Save settings</button>
</form>

<div class="card" id="grocery-extension">
  <h2>Grocery extension API token</h2>
  <p class="muted">
    Used by the
    <a href="https://github.com/jkshilling/food-buyer-extension" target="_blank" rel="noopener">food-buyer Chrome extension</a>
    to ship search results and picks back to this app. Paste it into the
    extension's Settings tab. Anyone with the token can write grocery events,
    so rotate it if it ever leaks.
  </p>
  <% if (tokenRotated) { %><div class="flash success">Token rotated. Update the extension with the new value.</div><% } %>
  <% if (groceryToken) { %>
    <p>
      <code style="user-select: all; padding: 4px 8px; background: #f4f4f4; border-radius: 4px; font-size: 13px;"><%= groceryToken %></code>
    </p>
    <form method="post" action="/settings/grocery-token/rotate" style="display:inline">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <button class="btn" type="submit"
              onclick="return confirm('Rotating invalidates the current token everywhere it is in use. Continue?');">
        Rotate token
      </button>
    </form>
    <a class="btn" href="/grocery">View captured data</a>
  <% } else { %>
    <p class="muted"><a href="/login">Log in</a> to see your personal extension token.</p>
  <% } %>
</div>

<div class="card" id="invites">
  <h2>Invite codes</h2>
  <p class="muted">
    Signup is invite-only. Mint a code below and send it to whoever you
    want to invite — they'll need it to create an account at
    <code>/signup</code>. Codes are single-use; once consumed, the row
    stays as an audit trail of who invited whom.
  </p>

  <% if (inviteCreated) { %>
    <div class="flash success">
      New invite code minted:
      <code style="user-select: all; padding: 4px 8px; background: #f4f4f4; border-radius: 4px; font-size: 14px; font-weight: 600;"><%= inviteCreated %></code>
      &nbsp;Copy it now; it will show in the list below masked after this page reload.
    </div>
  <% } %>
  <% if (inviteRevoked) { %>
    <div class="flash">Invite code revoked.</div>
  <% } %>

  <form method="post" action="/settings/invites/create" class="row" style="gap: 8px; align-items: center; margin-bottom: 12px;">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
    <input name="label" placeholder="Label (optional, e.g. 'Alice')" maxlength="80" style="min-width: 240px;" />
    <button class="btn primary" type="submit">Mint invite code</button>
  </form>

  <% if (inviteCodes && inviteCodes.length) { %>
    <table class="grid-table">
      <thead>
        <tr>
          <th>Code</th>
          <th>Label</th>
          <th>Status</th>
          <th>Created</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% inviteCodes.forEach(function(c) { %>
          <tr>
            <td><code><%= c.used_at ? '••••••••' + c.code.slice(-4) : c.code %></code></td>
            <td><%= c.label || '' %></td>
            <td>
              <% if (c.used_at) { %>
                <span class="muted small">used <%= formatDate(c.used_at) %></span>
              <% } else { %>
                <span class="muted small">unused</span>
              <% } %>
            </td>
            <td class="muted small"><%= formatDate(c.created_at) %></td>
            <td>
              <% if (!c.used_at) { %>
                <form method="post" action="/settings/invites/<%= c.id %>/revoke" style="display:inline" onsubmit="return confirm('Revoke this invite code?');">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                  <button class="link delete-link" type="submit">revoke</button>
                </form>
              <% } %>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } else { %>
    <p class="muted">No codes yet.</p>
  <% } %>
</div>

<script>
function addMember() {
  var tbody = document.getElementById('members');
  var tr = document.createElement('tr');
  function mealCell(meal) {
    return '<td><select name="member_' + meal + '">' +
      '<option value="plan">plan</option>' +
      '<option value="school">school</option>' +
      '<option value="skip">skip</option>' +
      '</select></td>';
  }
  tr.innerHTML = '<td><input name="member_name"/></td>' +
    '<td><select name="member_label"><option value="adult">adult</option><option value="child">child</option><option value="teen">teen</option></select></td>' +
    mealCell('breakfast') + mealCell('lunch') + mealCell('snack') + mealCell('dinner');
  tbody.appendChild(tr);
}
</script>
<%- include('partials/footer') %>
