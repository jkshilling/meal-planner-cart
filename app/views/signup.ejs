<%- include('partials/header') %>
<div style="max-width: 420px; margin: 40px auto;">
  <h1>Create account</h1>
  <% if (flash) { %><div class="flash <%= flash.type %>"><%= flash.message %></div><% } %>
  <section class="card">
    <form method="post" action="/signup" class="stack">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <label>Email
        <input type="email" name="email" required autofocus
               value="<%= email %>" autocomplete="email" />
      </label>
      <label>Password
        <input type="password" name="password" required minlength="8" autocomplete="new-password" />
        <span class="muted tiny">Minimum 8 characters.</span>
      </label>
      <label>Confirm password
        <input type="password" name="confirm" required minlength="8" autocomplete="new-password" />
      </label>
      <button class="btn primary" type="submit" style="width: 100%;">Create account</button>
    </form>
    <p class="muted tiny" style="margin: 14px 0 0; text-align: center;">
      Already have an account? <a href="/login">Sign in</a>
    </p>
  </section>
</div>
<%- include('partials/footer') %>
