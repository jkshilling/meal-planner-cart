<%- include('partials/header') %>
<h1>Products</h1>

<form method="get" action="/grocery/products" class="card">
  <label>Search by name or brand
    <input name="q" value="<%= q %>" placeholder="bread, kraft, ..." style="min-width: 260px" />
  </label>
  <button class="btn primary" type="submit">Search</button>
  <% if (q) { %><a class="btn" href="/grocery/products">Clear</a><% } %>
</form>

<div class="card">
  <% if (!rows.length) { %>
    <p class="muted">No products match.</p>
  <% } else { %>
    <table class="grid-table">
      <thead>
        <tr>
          <th></th>
          <th>Name</th>
          <th>Brand</th>
          <th>Size</th>
          <th>Latest price</th>
          <th>Per unit</th>
          <th>Last seen</th>
        </tr>
      </thead>
      <tbody>
        <% rows.forEach(function(p) { %>
          <tr>
            <td>
              <% if (p.image_url) { %><img src="<%= p.image_url %>" alt="" style="width:40px;height:40px;object-fit:contain"/><% } %>
            </td>
            <td><a href="/grocery/products/<%= p.id %>"><%= p.name %></a></td>
            <td><%= p.brand || '' %></td>
            <td><%= p.size_text || '' %></td>
            <td><%= p.latest_price != null ? '$' + p.latest_price.toFixed(2) : '' %></td>
            <td class="muted small"><%= p.unit_price || '' %></td>
            <td class="muted small"><%= p.last_seen_at %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } %>
</div>
<%- include('partials/footer') %>
