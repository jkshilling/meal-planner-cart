<%- include('partials/header') %>
<h1>Products <span class="count-badge"><%= rows.length %></span></h1>

<form method="get" action="/grocery/products" class="card">
  <label>Search by name
    <input name="q" value="<%= q %>" placeholder="bread, milk, broccoli..." style="min-width: 260px" />
  </label>
  <% if (categories && categories.length) { %>
    <label style="margin-left: 12px;">Category
      <select name="category" onchange="this.form.submit()">
        <option value="">all</option>
        <% categories.forEach(function(c) { %>
          <option value="<%= c.category %>" <%= category === c.category ? 'selected' : '' %>>
            <%= c.category %> (<%= c.n %>)
          </option>
        <% }) %>
      </select>
    </label>
  <% } %>
  <label class="inline" style="margin-left: 12px;">
    <input type="checkbox" name="favorites" value="1" <%= favoritesOnly ? 'checked' : '' %>
           onchange="this.form.submit()" />
    favorites only <% if (favoriteCount) { %><span class="muted tiny">(<%= favoriteCount %>)</span><% } %>
  </label>
  <button class="btn primary" type="submit">Search</button>
  <% if (q || favoritesOnly || category) { %><a class="btn" href="/grocery/products">Clear</a><% } %>
</form>

<div class="card">
  <% if (!rows.length) { %>
    <p class="muted">No products match.</p>
  <% } else { %>
    <table class="grid-table">
      <thead>
        <tr>
          <th style="width:24px"></th>
          <th></th>
          <th>Name</th>
          <th>Category</th>
          <th>Brand</th>
          <th>Size</th>
          <th>Latest price</th>
          <th>Per unit</th>
          <th>Last seen</th>
        </tr>
      </thead>
      <tbody>
        <% rows.forEach(function(p) { %>
          <tr>
            <td class="fav-cell">
              <form method="post" action="/grocery/products/<%= p.id %>/favorite" style="display:inline">
                <button class="fav-btn <%= p.is_favorite ? 'on' : '' %>"
                        type="submit"
                        title="<%= p.is_favorite ? 'unfavorite' : 'favorite — extension will prefer this product' %>">
                  <%= p.is_favorite ? '★' : '☆' %>
                </button>
              </form>
            </td>
            <td>
              <% if (p.image_url) { %><img src="<%= p.image_url %>" alt="" style="width:40px;height:40px;object-fit:contain"/><% } %>
            </td>
            <td><a href="/grocery/products/<%= p.id %>"><%= p.name %></a></td>
            <td class="muted small"><%= p.category || '' %></td>
            <td><%= p.brand || '' %></td>
            <td><%= p.size_text || '' %></td>
            <td><%= p.latest_price != null ? '$' + p.latest_price.toFixed(2) : '' %></td>
            <td class="muted small"><%= p.unit_price || '' %></td>
            <td class="muted small"><%= formatDate(p.last_seen_at) %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } %>
</div>

<% if (favoriteCount) { %>
  <p class="muted tiny">
    Favorites are exposed at <code>/grocery/favorites.json</code> for the
    food-buyer extension to bias its product picks.
  </p>
<% } %>
<%- include('partials/footer') %>
