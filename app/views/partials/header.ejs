<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= title %> — Meal Planner</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,600;9..144,700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/styles.css" />
  <script>
    // Exposed for JS that builds <form> markup dynamically (e.g. recipe
    // online-search results). Server-rendered forms read csrfToken directly
    // via EJS — no need to read this global.
    window.__CSRF = <%- JSON.stringify(csrfToken) %>;
  </script>
</head>
<body>
  <header class="topnav">
    <div class="brand">
      <svg class="brand-mark" viewBox="0 0 40 40" width="34" height="34"
           xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <defs>
          <linearGradient id="brandBowl" x1="0.5" y1="0" x2="0.5" y2="1">
            <stop offset="0%" stop-color="#c88b3a"/>
            <stop offset="100%" stop-color="#7c2d3c"/>
          </linearGradient>
        </defs>
        <!-- steam wisps -->
        <g stroke="#7e9b6f" stroke-width="1.8" stroke-linecap="round" fill="none">
          <path d="M14 11 C 12 14 16 16 14 19" opacity="0.55"/>
          <path d="M20 7 C 18 10 22 13 20 17" opacity="0.9"/>
          <path d="M26 11 C 24 14 28 16 26 19" opacity="0.55"/>
        </g>
        <!-- bowl body (half-circle below the rim) -->
        <path d="M7 22 L33 22 A13 13 0 0 1 7 22 Z" fill="url(#brandBowl)"/>
        <!-- rim highlight -->
        <line x1="7.5" y1="22" x2="32.5" y2="22"
              stroke="#faf7f2" stroke-width="1.5" stroke-linecap="round" opacity="0.45"/>
      </svg>
      <span class="brand-text">Meal Planner</span>
    </div>
    <nav>
      <%# Auth-gated nav links only render for logged-in users — every one %>
      <%# of these routes redirects to /login otherwise, so showing them %>
      <%# in the topnav of a logged-out page is misleading. %>
      <% if (currentUser) { %>
        <a href="/">Dashboard</a>
        <a href="/recipes">Recipes</a>
        <a href="/planner">Planner</a>
        <a href="/shopping">Shopping List</a>
        <a href="/grocery">Grocery</a>
        <a href="/grocery/products">Catalog</a>
        <a href="/settings">Settings</a>
        <%# User menu — username trigger expands to reveal Sign out (and any %>
        <%# future per-account actions). Keeps the visible nav focused on %>
        <%# product navigation, not session housekeeping. Closes on outside %>
        <%# click or Escape — see the script at the bottom of this file. %>
        <div class="user-menu" id="user-menu">
          <button class="user-menu-trigger" type="button"
                  aria-haspopup="true" aria-expanded="false"
                  aria-label="Account menu">
            <span><%= (currentUser.email || '').split('@')[0] %></span>
            <span class="user-menu-chevron" aria-hidden="true">▾</span>
          </button>
          <div class="user-menu-panel" role="menu">
            <div class="user-menu-email" title="<%= currentUser.email %>"><%= currentUser.email %></div>
            <form method="post" action="/logout" role="none">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
              <button class="user-menu-item" type="submit" role="menuitem">Sign out</button>
            </form>
          </div>
        </div>
      <% } else { %>
        <a href="/login" style="margin-left: 18px;">Sign in</a>
        <a href="/signup">Sign up</a>
      <% } %>
    </nav>
  </header>
  <% if (currentUser) { %>
  <script>
    (function() {
      var menu = document.getElementById('user-menu');
      if (!menu) return;
      var trigger = menu.querySelector('.user-menu-trigger');
      function close() {
        menu.classList.remove('open');
        trigger.setAttribute('aria-expanded', 'false');
      }
      trigger.addEventListener('click', function(e) {
        e.stopPropagation();
        var open = menu.classList.toggle('open');
        trigger.setAttribute('aria-expanded', open ? 'true' : 'false');
      });
      document.addEventListener('click', function(e) {
        if (!menu.contains(e.target)) close();
      });
      document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape' && menu.classList.contains('open')) {
          close();
          trigger.focus();
        }
      });
    })();
  </script>
  <% } %>
  <main>
