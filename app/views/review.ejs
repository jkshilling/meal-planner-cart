<%- include('partials/header') %>
<h1>Weekly Plan #<%= plan.id %></h1>
<p class="muted">Starts <%= plan.start_date %> · Status: <strong><%= plan.status %></strong></p>

<section class="card summary">
  <div><strong>Est. cost:</strong> $<%= plan.total_cost.toFixed(2) %> / budget $<%= plan.profile.budget_weekly.toFixed(2) %></div>
  <div><strong>Total prep:</strong> <%= plan.total_prep %> min</div>
  <div><strong>Avg health score:</strong> <%= plan.health_score %></div>
</section>

<% if (plan.total_cost > plan.profile.budget_weekly) { %>
  <div class="flash warn">Estimated cost exceeds your weekly budget. Consider swapping higher-cost slots.</div>
<% } %>

<% var byDay = {}; plan.items.forEach(function(it) { byDay[it.day] = byDay[it.day] || []; byDay[it.day].push(it); }); %>

<section class="card">
  <div class="planner-grid-header">
    <h2>Planner grid</h2>
    <label class="inline tiny muted" style="margin: 0;">
      <input type="checkbox" id="show-scoring" /> show scoring details
    </label>
  </div>
  <table class="grid-table plan-grid">
    <thead>
      <tr>
        <th>Day</th>
        <% plan.profile.meal_types.forEach(function(t) { %><th><%= t %></th><% }) %>
      </tr>
    </thead>
    <tbody>
      <% DAYS.forEach(function(d, idx) { %>
        <tr>
          <th><%= d %></th>
          <% plan.profile.meal_types.forEach(function(t) { %>
            <% var slot = (byDay[idx] || []).find(function(i) { return i.meal_type === t; }); %>
            <% var pairSides = (plan.profile.pair_sides_with || []).indexOf(t) >= 0; %>
            <td>
              <% if (slot) { %>
                <div class="slot">
                  <div class="slot-name"><%= slot.recipe_name || '— none —' %>
                    <% if (slot.locked) { %><span class="tag">locked</span><% } %>
                  </div>
                  <% if (slot.score) { %>
                    <div class="slot-meta"><%= slot.prep_time %>m · $<%= slot.score.factors.cost_estimate %></div>
                    <div class="slot-meta tiny">b:<%= slot.score.factors.budget %> p:<%= slot.score.factors.prep %> h:<%= slot.score.factors.health %> -r:<%= slot.score.factors.repetition_penalty %> +f:<%= slot.score.factors.favorite_boost %> +fit:<%= slot.score.factors.fit_boost %></div>
                  <% } %>
                  <% if (plan.status !== 'approved') { %>
                  <form method="post" action="/planner/update-slot" class="slot-form">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                    <input type="hidden" name="plan_id" value="<%= plan.id %>" />
                    <input type="hidden" name="day" value="<%= idx %>" />
                    <input type="hidden" name="meal_type" value="<%= t %>" />
                    <input type="hidden" name="target" value="main" />
                    <select name="recipe_id">
                      <option value="">— none —</option>
                      <% allRecipes.filter(function(r) { return r.meal_type === t; }).forEach(function(r) { %>
                        <option value="<%= r.id %>" <%= slot.recipe_id === r.id ? 'selected' : '' %>><%= r.name %></option>
                      <% }) %>
                    </select>
                    <button class="link" type="submit">swap</button>
                    <button class="link" type="submit" name="action" value="regenerate">regen</button>
                    <button class="link" type="submit" name="action" value="lock"><%= slot.locked ? 'unlock' : 'lock' %></button>
                  </form>
                  <% } %>

                  <% if (pairSides) { %>
                    <div class="slot-side">
                      <div class="slot-side-label">+ side</div>
                      <div class="slot-name"><%= slot.side_recipe_name || '— none —' %></div>
                      <% if (slot.side_score) { %>
                        <div class="slot-meta"><%= slot.side_prep_time %>m · $<%= slot.side_score.factors.cost_estimate %></div>
                        <div class="slot-meta tiny">pair:<%= slot.side_score.factors.pairing %> (<%= slot.side_score.factors.main_carb %>↔<%= slot.side_score.factors.side_carb %>)</div>
                      <% } %>
                      <% if (plan.status !== 'approved') { %>
                      <form method="post" action="/planner/update-slot" class="slot-form">
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                        <input type="hidden" name="plan_id" value="<%= plan.id %>" />
                        <input type="hidden" name="day" value="<%= idx %>" />
                        <input type="hidden" name="meal_type" value="<%= t %>" />
                        <input type="hidden" name="target" value="side" />
                        <select name="recipe_id">
                          <option value="">— none —</option>
                          <% allRecipes.filter(function(r) { return r.meal_type === 'side'; }).forEach(function(r) { %>
                            <option value="<%= r.id %>" <%= slot.side_recipe_id === r.id ? 'selected' : '' %>><%= r.name %></option>
                          <% }) %>
                        </select>
                        <button class="link" type="submit">swap</button>
                        <button class="link" type="submit" name="action" value="regenerate">regen</button>
                      </form>
                      <% } %>
                    </div>
                  <% } %>
                </div>
              <% } else { %>
                <span class="muted">—</span>
              <% } %>
            </td>
          <% }) %>
        </tr>
      <% }) %>
    </tbody>
  </table>
</section>

<script>
(function() {
  // Score factor lines are hidden by default — useful for debugging the
  // planner, distracting for everyone else. Toggle persists in localStorage.
  var box = document.getElementById('show-scoring');
  if (!box) return;
  var key = 'mp_show_scoring';
  box.checked = localStorage.getItem(key) === '1';
  document.body.classList.toggle('show-scoring', box.checked);
  box.addEventListener('change', function() {
    document.body.classList.toggle('show-scoring', box.checked);
    localStorage.setItem(key, box.checked ? '1' : '0');
  });
})();

// Async slot updates — no full page reload, scroll position survives.
// Each slot's swap/regen/lock form intercepts submit, POSTs with JSON
// Accept, and updates the .slot-name + .slot-meta + select in place.
(function() {
  function asNoneOrName(name) {
    return name || '— none —';
  }
  function findSlotContainer(form, target) {
    // The main form lives directly under .slot; the side form lives
    // under .slot .slot-side. Use the form's `target` hidden input to
    // decide which display elements to update.
    if (target === 'side') return form.closest('.slot-side');
    var slot = form.closest('.slot');
    return slot;
  }
  function updateMain(container, data) {
    // .slot-name is the first child of .slot (the side block has its
    // own .slot-name nested inside .slot-side); query directly to
    // grab the right one even when both exist.
    var nameEl = container.querySelector(':scope > .slot-name');
    if (nameEl) {
      // Preserve the locked tag element if currently present.
      nameEl.textContent = asNoneOrName(data.recipe_name) + ' ';
      if (data.locked) {
        var tag = document.createElement('span');
        tag.className = 'tag';
        tag.textContent = 'locked';
        nameEl.appendChild(tag);
      }
    }
    var metaEl = container.querySelector(':scope > .slot-meta');
    if (metaEl) {
      if (data.recipe_id) {
        metaEl.textContent = (data.prep_time || 0) + 'm · $' + (data.est_cost != null ? data.est_cost : 0);
      } else {
        metaEl.textContent = '';
      }
    }
    // Update the lock-button label so the next click toggles correctly.
    var lockBtn = container.querySelector(':scope > .slot-form button[value="lock"]');
    if (lockBtn) lockBtn.textContent = data.locked ? 'unlock' : 'lock';
  }
  function updateSide(container, data) {
    if (!container) return;
    var nameEl = container.querySelector('.slot-name');
    if (nameEl) nameEl.textContent = asNoneOrName(data.side_recipe_name);
    var metaEl = container.querySelector('.slot-meta');
    if (metaEl) {
      if (data.side_recipe_id) {
        metaEl.textContent = (data.side_prep_time || 0) + 'm · $' + (data.side_est_cost != null ? data.side_est_cost : 0);
      } else {
        metaEl.textContent = '';
      }
    }
  }

  document.querySelectorAll('.slot-form').forEach(function(form) {
    form.addEventListener('submit', function(e) {
      e.preventDefault();
      var fd = new FormData(form);
      // The submit button that was clicked tells us the action — swap
      // is "no action attr, value=empty"; regenerate and lock supply
      // their own name=action value=<action> on the button itself.
      var submitter = e.submitter;
      if (submitter && submitter.name === 'action') {
        fd.set('action', submitter.value);
      }
      var target = fd.get('target') || 'main';
      var slotContainer = findSlotContainer(form, target);

      // Disable buttons during the round-trip to prevent double-clicks.
      form.querySelectorAll('button').forEach(function(b) { b.disabled = true; });

      fetch(form.action, {
        method: 'POST',
        headers: { 'Accept': 'application/json' },
        body: fd
      })
      .then(function(r) { return r.ok ? r.json() : Promise.reject(new Error('HTTP ' + r.status)); })
      .then(function(data) {
        if (!data.ok) throw new Error(data.reason || 'update failed');
        if (target === 'side') {
          updateSide(slotContainer, data);
        } else {
          updateMain(slotContainer, data);
        }
        // Sync the select to the new recipe_id (regenerate can swap to
        // a different recipe than what was visible in the dropdown).
        var sel = form.querySelector('select[name="recipe_id"]');
        if (sel) {
          var rid = (target === 'side' ? data.side_recipe_id : data.recipe_id) || '';
          sel.value = String(rid || '');
        }
      })
      .catch(function(err) {
        alert('Slot update failed: ' + err.message + '. Reload and try again.');
      })
      .finally(function() {
        form.querySelectorAll('button').forEach(function(b) { b.disabled = false; });
      });
    });
  });
})();
</script>

<% if (plan.status !== 'approved') { %>
  <form method="post" action="/planner/approve" class="inline-form">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
    <input type="hidden" name="plan_id" value="<%= plan.id %>" />
    <button class="btn primary" type="submit">Approve plan</button>
  </form>
<% } else { %>
  <form method="post" action="/plan/<%= plan.id %>/build-shopping" class="inline-form">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
    <button class="btn primary" type="submit">Build shopping list →</button>
  </form>
  <a class="btn" href="/plan/<%= plan.id %>/shopping">View shopping list</a>
<% } %>
<%# Regenerate is always available — approval is just a workflow flag, not %>
<%# a lock. Without this, an approved plan that drew from a stale recipe %>
<%# library has no UI path to refresh after new recipes import. %>
<form method="post" action="/planner/generate" class="inline-form">
  <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
  <button class="btn" type="submit"
          onclick="return confirm('Generate a new plan? The current one stays in your history.');">
    Regenerate entire plan
  </button>
</form>
<a class="btn" href="/plans">All plans</a>

<%- include('partials/footer') %>
